# A bare command.
command
---
Command {
    name: "command",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 2,
}

# Commands with arguments.
foo arg
bar key=value
baz arg key=value
---
Command {
    name: "foo",
    args: [
        Argument {
            key: None,
            value: "arg",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 15,
}
Command {
    name: "bar",
    args: [
        Argument {
            key: Some(
                "key",
            ),
            value: "value",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 16,
}
Command {
    name: "baz",
    args: [
        Argument {
            key: None,
            value: "arg",
        },
        Argument {
            key: Some(
                "key",
            ),
            value: "value",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 17,
}

# Commands with tags.
foo [tag]
foo arg key=value [a,b c]
---
Command {
    name: "foo",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 71,
}
Command {
    name: "foo",
    args: [
        Argument {
            key: None,
            value: "arg",
        },
        Argument {
            key: Some(
                "key",
            ),
            value: "value",
        },
    ],
    prefix: None,
    tags: {
        "a",
        "b",
        "c",
    },
    silent: false,
    fail: false,
    line_number: 72,
}

# Command with tags before the command.
[tag] foo
[a,b c] foo arg
---
Command {
    name: "foo",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 111,
}
Command {
    name: "foo",
    args: [
        Argument {
            key: None,
            value: "arg",
        },
    ],
    prefix: None,
    tags: {
        "a",
        "b",
        "c",
    },
    silent: false,
    fail: false,
    line_number: 112,
}

# Commands with prefixes.
a: foo arg
b: bar key=value
---
a: Command {
a:     name: "foo",
a:     args: [
a:         Argument {
a:             key: None,
a:             value: "arg",
a:         },
a:     ],
a:     prefix: Some(
a:         "a",
a:     ),
a:     tags: {},
a:     silent: false,
a:     fail: false,
a:     line_number: 145,
a: }
b: Command {
b:     name: "bar",
b:     args: [
b:         Argument {
b:             key: Some(
b:                 "key",
b:             ),
b:             value: "value",
b:         },
b:     ],
b:     prefix: Some(
b:         "b",
b:     ),
b:     tags: {},
b:     silent: false,
b:     fail: false,
b:     line_number: 146,
b: }

# Failing commands.
! foo bar
---
Error: Command {
    name: "foo",
    args: [
        Argument {
            key: None,
            value: "bar",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: true,
    line_number: 184,
}

# Command with tags, prefixes, and failures.
prefix:[tag]! foo bar
---
prefix: Error: Command {
prefix:     name: "foo",
prefix:     args: [
prefix:         Argument {
prefix:             key: None,
prefix:             value: "bar",
prefix:         },
prefix:     ],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {
prefix:         "tag",
prefix:     },
prefix:     silent: false,
prefix:     fail: true,
prefix:     line_number: 202,
prefix: }

# Prefixes, commands, and keys can be empty.
"": "" ""=""
---
: Command {
:     name: "",
:     args: [
:         Argument {
:             key: Some(
:                 "",
:             ),
:             value: "",
:         },
:     ],
:     prefix: Some(
:         "",
:     ),
:     tags: {},
:     silent: false,
:     fail: false,
:     line_number: 224,
: }

# Prefixes, commands, and keys can be whitespace.
" ": " " " "=" "
---
 : Command {
 :     name: " ",
 :     args: [
 :         Argument {
 :             key: Some(
 :                 " ",
 :             ),
 :             value: " ",
 :         },
 :     ],
 :     prefix: Some(
 :         " ",
 :     ),
 :     tags: {},
 :     silent: false,
 :     fail: false,
 :     line_number: 246,
 : }

# Empty argument keys and values are fine.
command ""
command arg=""
command arg=
---
Command {
    name: "command",
    args: [
        Argument {
            key: None,
            value: "",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 268,
}
Command {
    name: "command",
    args: [
        Argument {
            key: Some(
                "arg",
            ),
            value: "",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 269,
}
Command {
    name: "command",
    args: [
        Argument {
            key: Some(
                "arg",
            ),
            value: "",
        },
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 270,
}

# > uses the rest of the line as the command name, regardless.
> command arg "quoted" key=value [tag] # comment
>
>!
> > >
---
Command {
    name: "command arg \"quoted\" key=value [tag] # comment",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 320,
}
Command {
    name: "",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 321,
}
Command {
    name: "!",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 322,
}
Command {
    name: "> >",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 323,
}

# > also works with prefix, tags, and error markers.
prefix: > command arg
!> command arg
[tag]> command arg
prefix:[tag]!> command arg
---
prefix: Command {
prefix:     name: "command arg",
prefix:     args: [],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {},
prefix:     silent: false,
prefix:     fail: false,
prefix:     line_number: 363,
prefix: }
Error: Command {
    name: "command arg",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: true,
    line_number: 364,
}
Command {
    name: "command arg",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 365,
}
prefix: Error: Command {
prefix:     name: "command arg",
prefix:     args: [],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {
prefix:         "tag",
prefix:     },
prefix:     silent: false,
prefix:     fail: true,
prefix:     line_number: 366,
prefix: }

# > respects \ line continuation, but it can't be escaped by \\.
> a very \
long line \
with line \
continuation
---
Command {
    name: "a very long line with line continuation",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 414,
}

> a line with \n ending with \\
another line
---
Command {
    name: "a line with \\n ending with \\another line",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 429,
}
