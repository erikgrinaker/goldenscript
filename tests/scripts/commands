# A bare command.
command
---
Command {
    name: "command",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 2,
}

# Commands with arguments.
foo arg
bar key=value
baz arg key=value
---
Command {
    name: "foo",
    args: [
        Positional(
            "arg",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 15,
}
Command {
    name: "bar",
    args: [
        KeyValue(
            "key",
            "value",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 16,
}
Command {
    name: "baz",
    args: [
        Positional(
            "arg",
        ),
        KeyValue(
            "key",
            "value",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 17,
}

# Commands with tags.
foo [tag]
foo arg key=value [a,b c]
---
Command {
    name: "foo",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 65,
}
Command {
    name: "foo",
    args: [
        Positional(
            "arg",
        ),
        KeyValue(
            "key",
            "value",
        ),
    ],
    prefix: None,
    tags: {
        "a",
        "b",
        "c",
    },
    silent: false,
    fail: false,
    line_number: 66,
}

# Command with tags before the command.
[tag] foo
[a,b c] foo arg
---
Command {
    name: "foo",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 102,
}
Command {
    name: "foo",
    args: [
        Positional(
            "arg",
        ),
    ],
    prefix: None,
    tags: {
        "a",
        "b",
        "c",
    },
    silent: false,
    fail: false,
    line_number: 103,
}

# Commands with prefixes.
a: foo arg
b: bar key=value
---
a: Command {
a:     name: "foo",
a:     args: [
a:         Positional(
a:             "arg",
a:         ),
a:     ],
a:     prefix: Some(
a:         "a",
a:     ),
a:     tags: {},
a:     silent: false,
a:     fail: false,
a:     line_number: 135,
a: }
b: Command {
b:     name: "bar",
b:     args: [
b:         KeyValue(
b:             "key",
b:             "value",
b:         ),
b:     ],
b:     prefix: Some(
b:         "b",
b:     ),
b:     tags: {},
b:     silent: false,
b:     fail: false,
b:     line_number: 136,
b: }

# Failing commands.
! foo bar
---
Error: Command {
    name: "foo",
    args: [
        Positional(
            "bar",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: true,
    line_number: 171,
}

# Command with tags, prefixes, and failures.
prefix:[tag]! foo bar
---
prefix: Error: Command {
prefix:     name: "foo",
prefix:     args: [
prefix:         Positional(
prefix:             "bar",
prefix:         ),
prefix:     ],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {
prefix:         "tag",
prefix:     },
prefix:     silent: false,
prefix:     fail: true,
prefix:     line_number: 188,
prefix: }

# Prefixes, commands, and keys can be empty.
"": "" ""=""
---
: Command {
:     name: "",
:     args: [
:         KeyValue(
:             "",
:             "",
:         ),
:     ],
:     prefix: Some(
:         "",
:     ),
:     tags: {},
:     silent: false,
:     fail: false,
:     line_number: 209,
: }

# Prefixes, commands, and keys can be whitespace.
" ": " " " "=" "
---
 : Command {
 :     name: " ",
 :     args: [
 :         KeyValue(
 :             " ",
 :             " ",
 :         ),
 :     ],
 :     prefix: Some(
 :         " ",
 :     ),
 :     tags: {},
 :     silent: false,
 :     fail: false,
 :     line_number: 229,
 : }

# Empty argument keys and values are fine.
command ""
command arg=""
command arg=
---
Command {
    name: "command",
    args: [
        Positional(
            "",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 249,
}
Command {
    name: "command",
    args: [
        KeyValue(
            "arg",
            "",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 250,
}
Command {
    name: "command",
    args: [
        KeyValue(
            "arg",
            "",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 251,
}

# > uses the rest of the line as the command name, regardless.
> command arg "quoted" key=value [tag] # comment
>
>!
> > >
---
Command {
    name: "command arg \"quoted\" key=value [tag] # comment",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 296,
}
Command {
    name: "",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 297,
}
Command {
    name: "!",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 298,
}
Command {
    name: "> >",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 299,
}

# > also works with prefix, tags, and error markers.
prefix: > command arg
!> command arg
[tag]> command arg
prefix:[tag]!> command arg
---
prefix: Command {
prefix:     name: "command arg",
prefix:     args: [],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {},
prefix:     silent: false,
prefix:     fail: false,
prefix:     line_number: 339,
prefix: }
Error: Command {
    name: "command arg",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: true,
    line_number: 340,
}
Command {
    name: "command arg",
    args: [],
    prefix: None,
    tags: {
        "tag",
    },
    silent: false,
    fail: false,
    line_number: 341,
}
prefix: Error: Command {
prefix:     name: "command arg",
prefix:     args: [],
prefix:     prefix: Some(
prefix:         "prefix",
prefix:     ),
prefix:     tags: {
prefix:         "tag",
prefix:     },
prefix:     silent: false,
prefix:     fail: true,
prefix:     line_number: 342,
prefix: }

# > respects \ line continuation, but it can't be escaped by \\.
> a very \
long line \
with line \
continuation
---
Command {
    name: "a very long line with line continuation",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 390,
}

> a line with \n ending with \\
another line
---
Command {
    name: "a line with \\n ending with \\another line",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 405,
}
