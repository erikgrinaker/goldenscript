# Comment at start.
#
# Comments can contain arbitrary characters, like 👋 and	(tab).

# Comment before command.
command id=1
---
Command {
    name: "command",
    args: [
        KeyValue(
            "id",
            "1",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 6,
}

command id=2 # Comment beside command.
---
Command {
    name: "command",
    args: [
        KeyValue(
            "id",
            "2",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 23,
}

command id=3
# Comment after command.
---
Command {
    name: "command",
    args: [
        KeyValue(
            "id",
            "3",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 40,
}

# Comment between blocks.

command id=4
---
Command {
    name: "command",
    args: [
        KeyValue(
            "id",
            "4",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 60,
}

command id=5 // Comment using //.
---
Command {
    name: "command",
    args: [
        KeyValue(
            "id",
            "5",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
