# Unquoted strings can be numeric.
0: 1 2 3=4
01: 23 45 67=89
---
0: Command {
0:     name: "1",
0:     args: [
0:         Positional(
0:             "2",
0:         ),
0:         KeyValue(
0:             "3",
0:             "4",
0:         ),
0:     ],
0:     prefix: Some(
0:         "0",
0:     ),
0:     tags: {},
0:     silent: false,
0:     fail: false,
0:     line_number: 2,
0: }
01: Command {
01:     name: "23",
01:     args: [
01:         Positional(
01:             "45",
01:         ),
01:         KeyValue(
01:             "67",
01:             "89",
01:         ),
01:     ],
01:     prefix: Some(
01:         "01",
01:     ),
01:     tags: {},
01:     silent: false,
01:     fail: false,
01:     line_number: 3,
01: }

# Unquoted strings can start with _.
_prefix: _command _arg _key=_value
---
_prefix: Command {
_prefix:     name: "_command",
_prefix:     args: [
_prefix:         Positional(
_prefix:             "_arg",
_prefix:         ),
_prefix:         KeyValue(
_prefix:             "_key",
_prefix:             "_value",
_prefix:         ),
_prefix:     ],
_prefix:     prefix: Some(
_prefix:         "_prefix",
_prefix:     ),
_prefix:     tags: {},
_prefix:     silent: false,
_prefix:     fail: false,
_prefix:     line_number: 45,
_prefix: }

# Unquoted strings can contain -_./@
prefix-_.: command-_./@ arg-_./@ key-_./@=value-_./@
---
prefix-_.: Command {
prefix-_.:     name: "command-_./@",
prefix-_.:     args: [
prefix-_.:         Positional(
prefix-_.:             "arg-_./@",
prefix-_.:         ),
prefix-_.:         KeyValue(
prefix-_.:             "key-_./@",
prefix-_.:             "value-_./@",
prefix-_.:         ),
prefix-_.:     ],
prefix-_.:     prefix: Some(
prefix-_.:         "prefix-_.",
prefix-_.:     ),
prefix-_.:     tags: {},
prefix-_.:     silent: false,
prefix-_.:     fail: false,
prefix-_.:     line_number: 68,
prefix-_.: }

# Single-quoted strings can contain any character, including newlines.
'➡️': '😀' '"👋"' '\t'='\0' '

  🚀

'
---
➡️: Command {
➡️:     name: "😀",
➡️:     args: [
➡️:         Positional(
➡️:             "\"👋\"",
➡️:         ),
➡️:         KeyValue(
➡️:             "\t",
➡️:             "\0",
➡️:         ),
➡️:         Positional(
➡️:             "\n\n  🚀\n\n",
➡️:         ),
➡️:     ],
➡️:     prefix: Some(
➡️:         "➡\u{fe0f}",
➡️:     ),
➡️:     tags: {},
➡️:     silent: false,
➡️:     fail: false,
➡️:     line_number: 91,
➡️: }

# Double-quoted strings can too.
"➡️": "😀" "'👋'" "\t"="\0" "

  🚀

"
---
➡️: Command {
➡️:     name: "😀",
➡️:     args: [
➡️:         Positional(
➡️:             "'👋'",
➡️:         ),
➡️:         KeyValue(
➡️:             "\t",
➡️:             "\0",
➡️:         ),
➡️:         Positional(
➡️:             "\n\n  🚀\n\n",
➡️:         ),
➡️:     ],
➡️:     prefix: Some(
➡️:         "➡\u{fe0f}",
➡️:     ),
➡️:     tags: {},
➡️:     silent: false,
➡️:     fail: false,
➡️:     line_number: 121,
➡️: }

# Single- and double-quoted strings can also be empty, but is not allowed in
# identifiers (prefixes, commands, and argument names). It is allowed as
# argument values.
command foo="" bar=''
---
Command {
    name: "command",
    args: [
        KeyValue(
            "foo",
            "",
        ),
        KeyValue(
            "bar",
            "",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 153,
}

# Escape sequences are respected both in single and double quotes, including
# both quote types.
'\\ \' \" \0 \n \r \t \\ \x00 \x7A \xff \u{1F44b}'
"\\ \' \" \0 \n \r \t \\ \x00 \x7A \xff \u{1F44b}"
---
Command {
    name: "\\ ' \" \0 \n \r \t \\ \0 z ÿ 👋",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 176,
}
Command {
    name: "\\ ' \" \0 \n \r \t \\ \0 z ÿ 👋",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 177,
}

# Quoted strings can contain the other, unescaped quote kind.
'"'
"'"
---
Command {
    name: "\"",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 199,
}
Command {
    name: "'",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 200,
}

# Quoted strings can also contain special characters like silencing ( and prefix
# : without them being interpreted as such.
'(command:' arg
---
Command {
    name: "(command:",
    args: [
        Positional(
            "arg",
        ),
    ],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 223,
}

# They can also contain comments.
'command # with comment'
---
Command {
    name: "command # with comment",
    args: [],
    prefix: None,
    tags: {},
    silent: false,
    fail: false,
    line_number: 240,
}
